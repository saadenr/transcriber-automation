# ============================================================
# Meeting Transcriber Bot — WhatsApp Edition
# Environment Variables
# ============================================================
# Set these in Railway.app → your n8n service → Variables tab
# ============================================================

# Your Meta WhatsApp access token
# Found in: Meta for Developers → Your App → WhatsApp → API Setup
# Example: EAABs...long_token...
WHATSAPP_ACCESS_TOKEN=your_meta_access_token_here

# Your WhatsApp Phone Number ID (NOT the phone number itself)
# Found in: Meta for Developers → Your App → WhatsApp → API Setup → Phone Number ID
# Example: 123456789012345
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Your free Groq API key (console.groq.com, no credit card)
# Example: gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=your_groq_api_key_here

# ============================================================
# TOTAL COST: $0.00 — All services are 100% free
# WhatsApp Cloud API: free up to 1,000 conversations/month
# Groq: free tier with generous daily limits
# ============================================================
